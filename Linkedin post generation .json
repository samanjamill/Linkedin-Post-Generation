    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst output = [];\n\nfor (const item of items) {\n  let cleanText = item.json.output || \"\";\n  cleanText = cleanText.trim();\n  cleanText = cleanText.replace(/^[\"']+|[\"']+$/g, \"\");\n  \n  output.push({\n    json: {\n      finalPost: cleanText\n    }\n  });\n}\n\nreturn output;"
      },
