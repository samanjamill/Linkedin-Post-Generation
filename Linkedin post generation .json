  "name": "Linkedin post generation",
  "nodes": [
    {
      "parameters": {
        "promptType": "define",
        "text": "=Create a professional LinkedIn post about: {{ $json.Topic }}. Make it engaging, informative, and include relevant hashtags. Keep it under 1300 characters.\n\nOutput ONLY the final post text itself, starting directly with the post content. Do not include a title, headers, explanations, rationale, character counts, tables, or any commentary about the post. Do not wrap it in quotes.",
        "options": {
          "systemMessage": "You are a professional LinkedIn content creator. Create engaging, professional posts that drive engagement. You must respond with ONLY the raw post text and hashtags — never include titles, section headers, explanations, rationale, character counts, tables, or any meta-commentary about what you changed or why."
        }
      },
